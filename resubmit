# Resubmit a batch job with correct output path and incremental naming.
# Scheduler (slurm/lsf/pbs) is detected from the directives in the script.
# Usage: resubmit.sh <path_to_job_script.sh>

if [ $# -eq 0 ]; then
    echo "Error: No SLURM script provided"
    echo "Usage: resubmit.sh <path_to_slurm.sh>"
    exit 1
fi

SLURM_SCRIPT="$1"

if [ ! -f "$SLURM_SCRIPT" ]; then
    echo "Error: SLURM script not found: $SLURM_SCRIPT"
    exit 1
fi

# Get the directory containing the SLURM script
SCRIPT_DIR=$(dirname "$SLURM_SCRIPT")
SCRIPT_DIR=$(cd "$SCRIPT_DIR" && pwd)  # Get absolute path

# Detect the scheduler from the directives present in the script.
if grep -q "^#SBATCH" "$SLURM_SCRIPT"; then
    SCHEDULER="slurm"
elif grep -q "^#BSUB" "$SLURM_SCRIPT"; then
    SCHEDULER="lsf"
elif grep -q "^#PBS" "$SLURM_SCRIPT"; then
    SCHEDULER="pbs"
else
    echo "Error: no #SBATCH/#BSUB/#PBS directives in $SLURM_SCRIPT — cannot tell the scheduler"
    exit 1
fi

# Use the parent folder name as the job name.
JOB_NAME=$(basename "$(dirname "$SCRIPT_DIR")")

# Find next available <scheduler>_N.out number
N=1
while [ -f "$SCRIPT_DIR/${SCHEDULER}_$N.out" ]; do
    N=$((N + 1))
done

OUTPUT_FILE="$SCRIPT_DIR/${SCHEDULER}_$N.out"

# Submit job with output redirected to the script's directory
echo "Submitting job from: $SLURM_SCRIPT"
echo "Scheduler: $SCHEDULER"
echo "Job name: $JOB_NAME"
echo "Output will be written to: $OUTPUT_FILE"

case "$SCHEDULER" in
    slurm) sbatch --job-name="$JOB_NAME" --output="$OUTPUT_FILE" "$SLURM_SCRIPT" ;;
    lsf)   bsub -J "$JOB_NAME" -o "$OUTPUT_FILE" < "$SLURM_SCRIPT" ;;
    pbs)   qsub -N "$JOB_NAME" -o "$OUTPUT_FILE" "$SLURM_SCRIPT" ;;
esac

if [ $? -eq 0 ]; then
    echo "Job submitted successfully"
else
    echo "Error: Job submission failed"
    exit 1
fi
