# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Config editor / bp-config backups (timestamped + legacy fixed-name)
*.bak
*.backup
*.backup[0-9]*

# Per-variant user config overrides (deep-merged onto the committed base)
.config.*.yaml

# Pipeline outputs
*_[0-9]*/
RunTime/
ToolOutputs/
Debug/
outputs/*
!outputs/README.md

# Personal pipelines
my_pipelines/*
!my_pipelines/README.md
!my_pipelines/template.py
!my_pipelines/template.ipynb

# Scripting tool scripts folder (user-authored two-phase scripts)
my_scripts/*
!my_scripts/README.md
!my_scripts/count_atoms.py
!my_scripts/filter_structures.py

# Ligands folder (cached ligand files)
ligands/*
!ligands/README.md

# PDBs folder (user structures)
pdbs/*.pdb
!pdbs/README.md

# Sequences folder (user sequences)
sequences/*
!sequences/README.md

# Tables folder (user tables)
tables/*
!tables/README.md

# MkDocs build output
site/

