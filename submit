#
# Batch Submission Script for BioPipelines
#
# This script submits a BioPipelines job to the configured batch scheduler
# (SLURM, LSF, or PBS/Torque), capturing job ids to chain dependent batches.
#
# Usage:
#     ./submit.sh <pipeline_script>
#

# Get the directory where submit script is located (biopipelines root)
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# Warn (once/day) if the checkout is behind the public GitHub repo. Never fatal.
[ -x "$SCRIPT_DIR/check-updates" ] && "$SCRIPT_DIR/check-updates" || true
# Locate config file. The submit script targets the cluster variant by default;
# users on a different machine variant should set BIOPIPELINES_CONFIG_VARIANT.
CONFIG_VARIANT="${BIOPIPELINES_CONFIG_VARIANT:-cluster}"
# Export it so the launched python sees the SAME variant. Otherwise bash parses
# config.<CONFIG_VARIANT>.yaml here while ConfigManager autodetects independently
# (possibly a different variant), generating scripts for the wrong scheduler.
export BIOPIPELINES_CONFIG_VARIANT="$CONFIG_VARIANT"
CONFIG_FILE="$SCRIPT_DIR/config.${CONFIG_VARIANT}.yaml"
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: config file not found: $CONFIG_FILE"
    echo "Set BIOPIPELINES_CONFIG_VARIANT=<variant> if you use a non-default config name."
    exit 1
fi
# The gitignored user overlay (.config.<variant>.yaml) is deep-merged on top of
# the committed base by the Python loader. We mirror that here so submit reads
# the same scheduler/modules/init the pipeline generation step used. Empty if no
# overlay exists.
OVERLAY_FILE="$SCRIPT_DIR/.config.${CONFIG_VARIANT}.yaml"
[ -f "$OVERLAY_FILE" ] || OVERLAY_FILE=""
# Read machine config (before Python is available).
#
# The schema has machine.env_manager and machine.scheduler as nested
# blocks (`{name, init, [modules]}`). We extract:
#   * env_manager.name      -> $ENV_MANAGER
#   * env_manager.init       -> sourced verbatim into this shell
#   * scheduler.init         -> sourced verbatim into this shell
#                               (typically: source /etc/profile.d/lmod.sh
#                               so `module` is available below)
#   * scheduler.modules      -> $SCHEDULER_MODULES, passed to `module load`
#
# Each helper awk extracts a `name:` key inside a parent block, or a
# bash-string list under an `init:` / `modules:` key inside that block.

# Decide once whether we have python3 + PyYAML available. If yes, use it
# for all YAML reads (robust against any valid YAML layout). Otherwise
# fall back to awk-based extractors that tolerate variable indentation.
#
# We resolve absolute paths for python3 and awk NOW, before any
# scheduler.init / module load can mutate PATH. On HPC sites that ship
# miniforge as a module, loading it shadows the system python3 with a
# base env that may not have PyYAML — using the resolved path keeps
# every read on the same interpreter we validated at startup. Even
# though all reads now happen up front, the absolute path is cheap
# insurance against future reorderings.
_PYTHON3=$(command -v python3 2>/dev/null || true)
_AWK=$(command -v awk 2>/dev/null || true)
if [ -n "$_PYTHON3" ] && "$_PYTHON3" -c 'import yaml' >/dev/null 2>&1; then
    _YAML_BACKEND=python
elif [ -n "$_AWK" ]; then
    _YAML_BACKEND=awk
else
    echo "ERROR: cannot parse $CONFIG_FILE — need either python3 with PyYAML or awk on PATH."
    exit 1
fi

# Extract a scalar `name:` value under `machine.<parent>.name`. Strips quotes.
# When the python backend is chosen, errors propagate (not redirected) so
# malformed YAML or schema mismatches surface immediately instead of
# returning empty and breaking the bootstrap downstream.
_yaml_name_in() {
    local parent="$1"
    if [ "$_YAML_BACKEND" = "python" ]; then
        "$_PYTHON3" -c "
import sys, yaml
def _merge(b, o):
    if isinstance(b, dict) and isinstance(o, dict):
        r = dict(b)
        for k, v in o.items():
            r[k] = _merge(r[k], v) if k in r else v
        return r
    return o
with open('$CONFIG_FILE') as f:
    d = yaml.safe_load(f) or {}
if '$OVERLAY_FILE':
    with open('$OVERLAY_FILE') as f:
        d = _merge(d, yaml.safe_load(f) or {})
v = (((d.get('machine') or {}).get('$parent') or {}).get('name'))
if v is not None:
    print(v)
"
        return
    fi
    # awk can't deep-merge; read the overlay first (bp-config writes the whole
    # machine.<parent> block there) and fall back to base only if absent.
    local _awk_name='
        /^machine:/ { in_machine = 1; next }
        in_machine && $0 ~ "^[[:space:]]+" parent ":" { in_parent = 1; next }
        in_parent && /^[[:space:]]+name:/ {
            sub(/^[[:space:]]+name:[[:space:]]*/, "")
            gsub(/["'\'']/, "")
            sub(/[[:space:]]*$/, "")
            print
            exit
        }
        in_parent && /^[[:space:]]{0,2}[^ ]/ { exit }
    '
    local _out=""
    [ -n "$OVERLAY_FILE" ] && _out=$("$_AWK" -v parent="$parent" "$_awk_name" "$OVERLAY_FILE")
    [ -z "$_out" ] && _out=$("$_AWK" -v parent="$parent" "$_awk_name" "$CONFIG_FILE")
    [ -n "$_out" ] && printf '%s\n' "$_out"
}

# Extract a list of strings under `machine.<parent>.<key>`. One value per
# line of stdout, with surrounding quotes stripped.
_yaml_list_in() {
    local parent="$1"
    local key="$2"
    if [ "$_YAML_BACKEND" = "python" ]; then
        "$_PYTHON3" -c "
import sys, yaml
def _merge(b, o):
    if isinstance(b, dict) and isinstance(o, dict):
        r = dict(b)
        for k, v in o.items():
            r[k] = _merge(r[k], v) if k in r else v
        return r
    return o
with open('$CONFIG_FILE') as f:
    d = yaml.safe_load(f) or {}
if '$OVERLAY_FILE':
    with open('$OVERLAY_FILE') as f:
        d = _merge(d, yaml.safe_load(f) or {})
xs = (((d.get('machine') or {}).get('$parent') or {}).get('$key')) or []
for x in xs:
    print(x)
"
        return
    fi
    local _awk_list='
        function indent_of(s,    i) {
            for (i = 1; i <= length(s); i++) {
                if (substr(s, i, 1) != " ") return i - 1
            }
            return length(s)
        }
        function flush(   s) {
            if (have == 0) return
            s = buf
            # Strip surrounding double or single quotes if any.
            if (substr(s, 1, 1) == "\"" && substr(s, length(s), 1) == "\"") {
                s = substr(s, 2, length(s) - 2)
            } else if (substr(s, 1, 1) == "'\''" && substr(s, length(s), 1) == "'\''") {
                s = substr(s, 2, length(s) - 2)
            }
            print s
            buf = ""
            have = 0
        }
        /^machine:/ { in_machine = 1; next }
        in_machine && $0 ~ "^[[:space:]]+" parent ":" { in_parent = 1; next }
        in_parent && $0 ~ "^[[:space:]]+" key ":" {
            in_list = 1
            list_indent = -1
            next
        }
        # Skip blank lines and comment lines anywhere inside the list.
        in_list && /^[[:space:]]*$/ { next }
        in_list && /^[[:space:]]*#/ { next }
        # New list item.
        in_list && /^[[:space:]]+- / {
            this_indent = indent_of($0)
            if (list_indent < 0) list_indent = this_indent
            # A "- " at less indent than our list ends this list.
            if (this_indent < list_indent) { flush(); exit }
            flush()
            sub(/^[[:space:]]*-[[:space:]]*/, "")
            buf = $0
            have = 1
            next
        }
        # Anything else inside the list: either a wrapped-scalar
        # continuation (indent > list_indent) or end-of-list.
        in_list {
            this_indent = indent_of($0)
            if (have && list_indent >= 0 && this_indent > list_indent) {
                sub(/^[[:space:]]+/, "")
                sub(/[[:space:]]+$/, "")
                buf = buf " " $0
                next
            }
            flush()
            exit
        }
        END { flush() }
    '
    # awk can't deep-merge; fall back per KEY (not per block). Read the list
    # from the overlay only if the overlay actually defines machine.<parent>.<key>
    # (e.g. bp-config auto writes the whole block); otherwise read base, so a
    # leaf-only overlay (bp-config set machine.scheduler.name lsf) doesn't wipe
    # the base's init/modules.
    local _src="$CONFIG_FILE"
    if [ -n "$OVERLAY_FILE" ] && \
       "$_AWK" -v parent="$parent" -v key="$key" '
           /^machine:/ { m=1; next }
           m && $0 ~ "^[[:space:]]+" parent ":" { p=1; next }
           p && $0 ~ "^[[:space:]]+" key ":" { found=1 }
           p && /^[[:space:]]{0,2}[^ ]/ { p=0 }
           END { exit !found }' "$OVERLAY_FILE"; then
        _src="$OVERLAY_FILE"
    fi
    "$_AWK" -v parent="$parent" -v key="$key" "$_awk_list" "$_src"
}

# Read every YAML value we need up front, before any eval / module load
# runs. Sourcing scheduler.init or `module load`-ing miniforge can shadow
# the system python3/awk on PATH (e.g. miniforge's base env without
# PyYAML), which would silently break later reads. By doing all parsing
# now, the bootstrap is immune to whatever the user's init does to PATH.
ENV_MANAGER=$(_yaml_name_in env_manager)
SCHEDULER=$(_yaml_name_in scheduler)
SCHEDULER_INIT=$(_yaml_list_in scheduler init)
SCHEDULER_MODULES=$(_yaml_list_in scheduler modules | xargs)
ENV_MANAGER_INIT=$(_yaml_list_in env_manager init)

if [ -z "$ENV_MANAGER" ]; then
    echo "ERROR: machine.env_manager.name not found in $CONFIG_FILE"
    echo "Please add the dict-form env_manager block under 'machine:'."
    exit 1
fi

if [ -z "$SCHEDULER" ]; then
    echo "ERROR: machine.scheduler.name not found in $CONFIG_FILE"
    echo "Please add the dict-form scheduler block under 'machine:'."
    exit 1
fi

case "$SCHEDULER" in
    slurm) ;;
    lsf|pbs)
        echo "WARNING: $SCHEDULER support is new. If a job is rejected or mis-scheduled, override with ${SCHEDULER}_options in Resources() and open an issue at https://github.com/locbp-uzh/biopipelines/issues"
        ;;
    *)
        echo "ERROR: machine.scheduler.name='$SCHEDULER' is not a batch scheduler."
        echo "$0 submits to a batch scheduler (slurm/lsf/pbs); for '$SCHEDULER' run pipelines inline with bp-run instead."
        exit 1
        ;;
esac

# Source the scheduler.init lines first so `module` (and any other host
# primitives the user named) are on PATH before we try `module load`.
if [ -n "$SCHEDULER_INIT" ]; then
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        eval "$line"
    done <<< "$SCHEDULER_INIT"
fi

# Load environment modules from scheduler.modules. If modules are configured
# but `module` isn't on PATH after scheduler.init, abort with a useful
# message — otherwise the next failure ("mamba: command not found",
# etc.) is opaque and hard to trace back to a missing lmod source.
if [ -n "$SCHEDULER_MODULES" ]; then
    if ! command -v module >/dev/null 2>&1 && ! type module >/dev/null 2>&1; then
        echo "ERROR: 'module' command not found, but machine.scheduler.modules is non-empty."
        echo "Check machine.scheduler.init in $CONFIG_FILE — it should source"
        echo "the host's lmod profile (e.g. /etc/profile.d/lmod.sh) before submit"
        echo "tries to load modules."
        exit 1
    fi
    module load $SCHEDULER_MODULES
fi

# Source the env-manager init lines (typically the shell-hook eval).
if [ -n "$ENV_MANAGER_INIT" ]; then
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        eval "$line"
    done <<< "$ENV_MANAGER_INIT"
fi

set -e  # Exit on any error

# Check if biopipelines env exists. The pip env_manager has no shared
# `env list` / `activate` concept — assume the user's current python
# already has biopipelines installed (e.g. inside a venv they activated
# manually) and skip the check.
if [ "$ENV_MANAGER" = "pip" ]; then
    echo "Using pip env_manager — assuming biopipelines is importable in the current python."
elif $ENV_MANAGER env list | grep -qw "biopipelines"; then
    echo "Activating biopipelines environment..."
    $ENV_MANAGER activate biopipelines
else
    echo "ERROR: biopipelines environment not found."
    echo ""
    echo "Please install it first (see docs/UserManual.md):"
    echo "  $ENV_MANAGER env create -f environments/biopipelines.yaml"
    echo "  $ENV_MANAGER activate biopipelines"
    echo "  pip install -e ."
    exit 1
fi
#echo ""

# Function to print usage
usage() {
    echo "Usage: $0 [-v|--verbose] <pipeline_script>"
    echo ""
    echo "Run a BioPipelines script and submit the generated job to the configured scheduler (SLURM/LSF/PBS)"
    echo ""
    echo "Options:"
    echo "  -v, --verbose    Show full pipeline generation output"
    echo ""
    echo "Arguments:"
    echo "  pipeline_script  Path to pipeline script (.py or .ipynb)"
    echo ""
    echo "Examples:"
    echo "  $0 pipeline.py                               # Run pipeline.py"
    echo "  $0 -v pipeline.py                            # Run with full output"
    echo "  $0 pipeline.ipynb                             # Run from notebook"
    echo "  $0 example_pipelines/ligandmpnn_boltz2.py    # Run specific pipeline"
    echo ""
}

# Glob pattern (basename) for per-batch scheduler scripts, stemmed by scheduler.
batch_glob() { echo "${SCHEDULER}_batch*.sh"; }
# Single-batch script basename, stemmed by scheduler.
single_script_name() { echo "${SCHEDULER}.sh"; }

# Submit one script and echo the captured job id on success, or print an
# error and return 1. Scheduler-specific: SLURM sbatch --parsable, LSF bsub
# (parse "Job <NNN> is submitted"), PBS qsub (prints the bare job id).
# Args: <script> <job_name> <output_path>
submit_one() {
    local script="$1" job_name="$2" output_path="$3"
    local out exit_code jid
    case "$SCHEDULER" in
        slurm)
            out=$(sbatch --parsable --job-name="$job_name" --output="$output_path" "$script" 2>&1)
            exit_code=$?
            jid="$out"
            ;;
        lsf)
            # bsub reads the script from stdin; -J name, -o output.
            out=$(bsub -J "$job_name" -o "$output_path" < "$script" 2>&1)
            exit_code=$?
            # "Job <12345> is submitted to queue <normal>."
            jid=$(echo "$out" | sed -n 's/.*Job <\([0-9][0-9]*\)>.*/\1/p' | head -1)
            ;;
        pbs)
            # qsub prints the job id (e.g. "12345.headnode") on stdout.
            out=$(qsub -N "$job_name" -o "$output_path" "$script" 2>&1)
            exit_code=$?
            jid=$(echo "$out" | head -1 | tr -d '[:space:]')
            ;;
        *)
            echo "✗ Unknown scheduler '$SCHEDULER' — cannot submit" >&2
            return 1
            ;;
    esac
    if [ $exit_code -ne 0 ] || [ -z "$jid" ] || echo "$out" | grep -qi "error\|invalid\|failed"; then
        echo "✗ Submission failed ($SCHEDULER): $out" >&2
        return 1
    fi
    echo "$jid"
}

# Function to run pipeline and execute submission commands
run_pipeline_and_submit() {
    local pipeline_script="$1"
    local verbose="$2"

    echo "Generating pipeline: $pipeline_script"

    # Run the pipeline and capture output
    local pipeline_output=$(python "$pipeline_script" 2>&1)
    local exit_code=$?

    if [ "$verbose" = "1" ]; then
        echo ""
        echo "$pipeline_output"
    else
        # Even in non-verbose mode, show full tracebacks and error context
        local error_output=$(echo "$pipeline_output" | awk '
            /^Traceback \(most recent call last\)/ { capture=1 }
            capture { print }
            !capture && /^[A-Za-z]*[Ee]rror:|^[A-Za-z]*[Ee]xception:/ { print }
        ')
        if [ -n "$error_output" ]; then
            echo ""
            echo "$error_output"
        fi
    fi
    #echo ""

    if [ $exit_code -ne 0 ]; then
        echo "Pipeline generation failed with exit code $exit_code"
        if [ "$verbose" != "1" ]; then
            echo "Re-run with -v to see full output"
        fi
        echo ""
        return 1
    fi

    # Extract ALL runtime directories from pipeline output
    local runtime_dirs=$(echo "$pipeline_output" | grep -o '/[^ ]*/RunTime' | sort -u)

    if [ -z "$runtime_dirs" ]; then
        echo "No runtime directories found in pipeline output"
        return 1
    fi

    #echo ""
    echo "Found $(echo "$runtime_dirs" | wc -l) pipeline(s) to submit"
    echo "=========================================="
    #echo ""

    local total_jobs_submitted=0

    # Process each runtime directory
    while IFS= read -r runtime_dir; do
        if [ -z "$runtime_dir" ] || [ ! -d "$runtime_dir" ]; then
            continue
        fi

        # Extract pipeline name from runtime directory
        local pipeline_name=$(basename "$(dirname "$runtime_dir")")
        echo "Processing pipeline: $pipeline_name"
        echo "Runtime directory: $runtime_dir"
        #echo ""

        # Check for batch files (multi-batch pipeline), stemmed by scheduler.
        local batch_files=$(ls "$runtime_dir"/$(batch_glob) 2>/dev/null | sort -V)

        if [ -n "$batch_files" ]; then
            # Multi-batch pipeline
            echo "Detected multi-batch pipeline"
            echo "Submitting jobs with dependencies..."
            echo "------------------------------------------"
            #echo ""

            local job_count=0
            # Per-batch job-id map: batch number (zero-padded 3-digit) -> scheduler job id.
            # Populated as each batch is submitted; consulted to substitute every
            # <JOBID_BATCH_NNN> placeholder remaining in the next batch's script.
            # Batches emit in numeric order (sort -V above) and parents always have
            # lower numbers than their children, so the map is always populated for
            # any placeholder we need to substitute.
            declare -A batch_job_id

            for batch_file in $batch_files; do
                job_count=$((job_count + 1))

                # Extract batch number for job naming
                local batch_num=$(basename "$batch_file" | grep -o '[0-9]\+')
                local batch_key=$(printf "%03d" "$batch_num")

                # Replace every <JOBID_BATCH_NNN> placeholder remaining in this batch
                # script with the captured id for batch NNN. One sed pass per
                # distinct placeholder; loop until none remain to handle multi-parent
                # dependency strings.
                local pending_placeholders
                pending_placeholders=$(grep -o "<JOBID_BATCH_[0-9][0-9][0-9]>" "$batch_file" 2>/dev/null | sort -u)
                if [ -n "$pending_placeholders" ]; then
                    while IFS= read -r placeholder; do
                        local ph_key=$(echo "$placeholder" | grep -o "[0-9][0-9][0-9]")
                        local ph_jobid="${batch_job_id[$ph_key]}"
                        if [ -z "$ph_jobid" ]; then
                            echo "✗ Batch $batch_num references batch $ph_key but its job id was never captured"
                            return 1
                        fi
                        echo "  Resolving $placeholder -> $ph_jobid"
                        sed -i "s/$placeholder/$ph_jobid/g" "$batch_file"
                    done <<< "$pending_placeholders"
                    if grep -q "<JOBID_BATCH_" "$batch_file"; then
                        echo "Warning: Failed to replace some <JOBID_BATCH_NNN> placeholders in $batch_file"
                    fi
                fi

                local job_name="${pipeline_name}_batch${batch_num}"
                local output_path="$runtime_dir/job_batch${batch_num}.out"

                # Submit and capture job ID
                echo "Submitting batch $batch_num..."
                echo "  Job name: $job_name"
                echo "  Output: $output_path"
                local resolved_dep
                resolved_dep=$(grep -o "\(afterok\|after\):[0-9:]*\|done([0-9]*)\|started([0-9]*)" "$batch_file" | head -1)
                if [ -n "$resolved_dep" ]; then
                    echo "  Dependency: $resolved_dep"
                fi

                local submit_jid
                if submit_jid=$(submit_one "$batch_file" "$job_name" "$output_path"); then
                    batch_job_id[$batch_key]="$submit_jid"
                    echo "✓ Batch $batch_num submitted: Job ID $submit_jid"
                    total_jobs_submitted=$((total_jobs_submitted + 1))
                else
                    echo "✗ Failed to submit batch $batch_num"
                    return 1
                fi
                #echo ""
            done

            echo "Pipeline $pipeline_name: $job_count batch(es) submitted"
            #echo ""
        else
            # Single batch pipeline - look for the scheduler's single script.
            local job_script="$runtime_dir/$(single_script_name)"
            if [ -f "$job_script" ]; then
                echo "Detected single-batch pipeline"
                echo "Submitting job..."
                echo "------------------------------------------"
                #echo ""

                # Extract job name from pipeline output
                local job_name=$(echo "$pipeline_output" | grep -A1 "$runtime_dir" | grep -o "Job: .*" | sed 's/Job: //' | head -1)
                if [ -z "$job_name" ]; then
                    job_name="$pipeline_name"
                fi

                local output_path="$runtime_dir/${SCHEDULER}.out"
                local submit_jid
                if submit_jid=$(submit_one "$job_script" "$job_name" "$output_path"); then
                    echo "✓ Job submitted: Job ID $submit_jid"
                    total_jobs_submitted=$((total_jobs_submitted + 1))
                else
                    echo "✗ Failed to submit job"
                    return 1
                fi
                #echo ""
            else
                echo "Warning: No $SCHEDULER script found in $runtime_dir"
                #echo ""
            fi
        fi
    done <<< "$runtime_dirs"

    echo "=========================================="
    echo "All pipelines submitted. Total jobs: $total_jobs_submitted"
}

# Main execution
main() {
    local verbose=0
    local pipeline_script=""

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage
                return 0
                ;;
            -v|--verbose)
                verbose=1
                shift
                ;;
            *)
                pipeline_script="$1"
                shift
                ;;
        esac
    done

    # Require a pipeline script argument
    if [ -z "$pipeline_script" ]; then
        echo "Error: No pipeline script specified"
        echo ""
        usage
        return 1
    fi

    # Check if pipeline script exists
    if [ ! -f "$pipeline_script" ]; then
        echo "Error: Pipeline script not found: $pipeline_script"
        return 1
    fi

    # Run the pipeline and submit jobs
    run_pipeline_and_submit "$pipeline_script" "$verbose"
}

# Run main function with all arguments
main "$@"